<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title><%= title %></title>
</head>
<body>
    <%- include('navbar') %>
    <div class="userHead">
        <h1>All Users</h1>
    </div>
    <div class="userBoard">
        <form action="" method="POST" class="userForm">
            <input type="text" name="name" size="40" id="name" placeholder="Add your name" required>
            <button type="submit">Add</button>
        </form>
        <ul class="userList">
            <% toolUsers.forEach((user) => { %>
                <li class="userInfo">
                    <p><%= user.tooluser_name %></p>
                    <div class="btn">
                        <button title="Delete user" onclick="openDeleteModal('<%= user.tooluser_id %>')">X</button>
                    </div>
                </li>
                <div id="deleteModal">
                    <div class="modalBox">
                        <h3>Admin Access</h3>
                        <p>Please enter the password to delete user.</p>

                        <!-- Form will be updated by JS to point to the right tooluser_id -->
                        <form id="deleteForm" method="POST" class="formModal">
                            <input type="password" name="adminPass" placeholder="Password" required>
                            <br>
                            <button type="submit" class="delBtn">
                                Delete
                            </button>
                            <button type="button" onclick="closeModal()" class="cancelBtn">
                                Cancel
                            </button>
                        </form>
                    </div>
                </div>
            <% }) %>
        </ul>
    </div>
    <div class="footPage">
        <%- include('footer') %>
    </div>

    <script>
        const modal = document.getElementById('deleteModal');
        const form = document.getElementById('deleteForm');

        function openDeleteModal(userId) {
            // Dynamically set the form's action to the correct ID
            form.action = `/delete-user/${userId}`;
            modal.style.display = 'block';
        }

        function closeModal() {
            modal.style.display = 'none';
        }

        // Close if they click outside the white box
        window.onclick = function(event) {
            if (event.target == modal) closeModal();
        }
    </script>
</body>
</html>