<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <title><%= title %></title>
</head>
<body>
    <div class="mainPage">
        <div class="mainImg">
            <img src="/images/main2.jpg" alt="tools">
        </div>
        <div class="mainText">
            <h1>Don't buy it, borrow it!</h1>
            <p>Own less, do more. The easiest way to share, lend and track tools with people you trust.</p>
        </div>
        <div class="mainBtn">
            <a href="/inventory">
                <button class="startBtn">
                    Get Started
                    <div class="icon">
                            <svg
                                height="24"
                                width="24"
                                viewBox="0 0 24 24"
                                xmlns="http://www.w3.org/2000/svg"
                            >
                                <path d="M0 0h24v24H0z" fill="none"></path>
                                <path
                                    d="M16.172 11l-5.364-5.364 1.414-1.414L20 12l-7.778 7.778-1.414-1.414L16.172 13H4v-2z"
                                    fill="currentColor">
                                </path>
                            </svg>
                    </div>
                </button>
            </a>
        </div>
    </div>
</body>
</html>